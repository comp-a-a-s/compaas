# CrackPie Configuration

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=

# Optional: Override data directory (default: ./company_data)
# CRACKPIE_DATA_DIR=./company_data

# Optional: Override project output directory (default: ~/projects)
# PROJECTS_OUTPUT_DIR=~/projects

# Web Dashboard Configuration
# CRACKPIE_API_HOST=127.0.0.1
# CRACKPIE_API_PORT=8420
# CRACKPIE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Debug mode (enables hot-reload and verbose output)
# CRACKPIE_DEBUG=false
