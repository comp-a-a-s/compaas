# COMPaaS Configuration

# ---------------------------------------------------------------------------
# AI Provider — choose ONE of the three options below
# ---------------------------------------------------------------------------

# Option 1: Anthropic Cloud (default)
# Agents run via the Claude Code CLI.  Set your Anthropic API key:
ANTHROPIC_API_KEY=

# Option 2: OpenAI
# Set provider to "openai" in the Setup Wizard or Settings, then add your key:
# OPENAI_API_KEY=sk-...

# Option 3: Local Model (Ollama, LM Studio, llama.cpp, etc.)
# Set provider to "openai_compat" in the Setup Wizard or Settings.
# All connection details (base URL, model name) are stored in company_data/config.yaml.
# No extra env vars required for local servers.

# Phase 2 — Route ALL agents through a LiteLLM proxy (optional)
# Start the proxy first:  litellm --model ollama/llama3.2 --port 4000
# Then enable "Proxy mode" in Settings and set the proxy URL to http://localhost:4000

# ---------------------------------------------------------------------------
# Data & server
# ---------------------------------------------------------------------------

# Optional: Override data directory (default: ./company_data)
# COMPAAS_DATA_DIR=./company_data

# Optional: Override project output directory (default: ~/projects)
# PROJECTS_OUTPUT_DIR=~/projects

# Web Dashboard
# COMPAAS_API_HOST=127.0.0.1
# COMPAAS_API_PORT=8420
# COMPAAS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# COMPAAS_CORS_METHODS=GET
# Optional admin token for remote-sensitive writes (e.g. /api/integrations)
# If unset, integration writes are limited to loopback/local clients.
# COMPAAS_ADMIN_TOKEN=change-me
#
# Webhook signature secrets (recommended when using GitHub/Slack integrations)
# COMPAAS_GITHUB_WEBHOOK_SECRET=change-me
# COMPAAS_SLACK_SIGNING_SECRET=change-me
#
# Debug mode (enables hot-reload and verbose output)
# COMPAAS_DEBUG=false
